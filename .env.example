# Copy to .env and adjust. The stack reads .env at startup.

# --- Probe targets (comma-separated) ---
PING_TARGETS=8.8.8.8,1.1.1.1,google.com
DNS_TARGETS=google.com,cloudflare.com,github.com
HTTP_TARGETS=https://www.google.com,https://1.1.1.1

# --- Probe timing ---
PROBE_INTERVAL_SECONDS=30
PING_COUNT=10
PING_PACKET_INTERVAL_SECONDS=0.5
PING_PACKET_TIMEOUT_SECONDS=2
HTTP_TIMEOUT_SECONDS=5

# --- Per-hop path monitoring (MTR-style) ---
PATH_TARGETS=8.8.8.8                  # comma list; traced hop-by-hop
PATH_INTERVAL_SECONDS=60
PATH_COUNT=3                          # packets per hop (loss resolution)

# --- Auto-labeling ---
ENRICH=true                          # rDNS host + owner labels on targets & hops

# --- Speedtest + bufferbloat (Ookla CLI; consumes real bandwidth) ---
LOADTEST_ENABLED=true                 # set false on metered links / on the Mac
LOADTEST_INTERVAL_SECONDS=3600        # how often to run the load test
LOADTEST_START_DELAY_SECONDS=30
# SPEEDTEST_SERVER_ID=                # optional: pin an Ookla server id

# --- WhatsApp alerts ---
# Enable on the always-on host only (e.g. via docker-compose.override.yml).
ALERTS_ENABLED=false
WHATSAPP_PROVIDER=callmebot          # or: twilio
ALERT_TARGETS=internet               # comma list; "internet" = all-providers-down
ALERT_TZ=UTC                         # e.g. Asia/Dubai for local times in messages
# CallMeBot (free relay):
# CALLMEBOT_PHONE=9715XXXXXXXX        # your WhatsApp number, intl format, no '+'
# CALLMEBOT_APIKEY=123456
# Twilio (alternative):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+9715XXXXXXXX

# --- Grafana login ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
